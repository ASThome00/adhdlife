{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "default",
  "description": "Default capabilities for ADHD Life desktop app",
  "windows": ["main"],
  "permissions": [
    "core:default",
    "sql:default",
    "sql:allow-execute",
    "updater:default",
    "process:allow-restart",
    "dialog:allow-save",
    {
      "identifier": "fs:allow-write-text-file",
      "allow": [{ "path": "**" }]
    }
  ]
}
