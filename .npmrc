# React Native / Expo SDK 51 tooling resolves packages with bare
# require.resolve() calls that assume an npm-style flat node_modules
# (e.g. @react-native/gradle-plugin from settings.gradle, expo-asset from
# export:embed). pnpm's default isolated layout hides transitive deps and
# breaks Android release builds — hoisted is Expo's supported pnpm config.
node-linker=hoisted
